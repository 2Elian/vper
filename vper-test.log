 action_input: {'code': 'import json\n\n# Read Patient data\nwith open(\'json/Patient.json\', \'r\') as f:\n    patient_data = json.load(f)\n\n# Read Examination data\nwith open(\'json/Examination.json\', \'r\') as f:\n    exam_data = json.load(f)\n\n# Create lookup dictionaries\npatient_dict = {p[\'ID\']: p for p in patient_data[\'records\']}\nexam_records = exam_data[\'records\']\n\n# Filter examinations with severe thrombosis (1 or 2)\nsevere_thrombosis = [e for e in exam_records if e.get(\'Thrombosis\') in [\'1\', \'2\']]\n\n# Join with patient data and extract required fields\nresults = []\nfor exam in severe_thrombosis:\n    pid = exam[\'ID\']\n    if pid in patient_dict:\n        patient = patient_dict[pid]\n        results.append({\n            \'ID\': pid,\n            \'SEX\': patient.get(\'SEX\'),\n            \'Diagnosis\': patient.get(\'Diagnosis\')\n        })\n\nprint(f"Found {len(results)} patients with severe thrombosis")\nprint("\\nSample results:")\nfor r in results[:10]:\n    print(r)\n'} 
