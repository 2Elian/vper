 action_input: {'code': 'import pandas as pd\nimport json\n\n# Load expense data from JSON\nwith open(\'json/expense.json\', \'r\') as f:\n    expense_data = json.load(f)\nexpenses_df = pd.DataFrame(expense_data[\'records\'])\n\n# Load budget data from CSV\nbudget_df = pd.read_csv(\'csv/budget.csv\')\n\n# Load event data from JSON\nwith open(\'json/event.json\', \'r\') as f:\n    event_data = json.load(f)\nevents_df = pd.DataFrame(event_data[\'records\'])\n\nprint("=== Expense Data ===")\nprint(expenses_df.head())\nprint(f"\\nTotal expenses: {len(expenses_df)}")\n\nprint("\\n=== Budget Data ===")\nprint(budget_df.head())\nprint(f"\\nTotal budgets: {len(budget_df)}")\n\nprint("\\n=== Event Data ===")\nprint(events_df.head())\nprint(f"\\nTotal events: {len(events_df)}")\n\n# Join expense with budget on link_to_budget\nmerged_df = expenses_df.merge(\n    budget_df,\n    left_on=\'link_to_budget\',\n    right_on=\'budget_id\',\n    how=\'left\'\n)\n\nprint("\\n=== After Expense-Budget Join ===")\nprint(merged_df[[\'expense_description\', \'cost\', \'category\']].head())\n\n# Join with event on link_to_event (from budget)\nfinal_df = merged_df.merge(\n    events_df,\n    left_on=\'link_to_event\',\n    right_on=\'event_id\',\n    how=\'left\'\n)\n\nprint("\\n=== Final Joined Data (Expense + Budget + Event) ===")\nprint(final_df[[\'expense_description\', \'cost\', \'category\', \'event_name\', \'event_date\']].head(10))\n\n# Find minimum cost event\nmin_cost_row = final_df.loc[final_df[\'cost\'].idxmin()]\nprint("\\n=== Minimum Cost Event ===")\nprint(f"Event Name: {min_cost_row[\'event_name\']}")\nprint(f"Cost: ${min_cost_row[\'cost\']}")\nprint(f"Category: {min_cost_row[\'category\']}")\nprint(f"Description: {min_cost_row[\'expense_description\']}")\nprint(f"Date: {min_cost_row[\'expense_date\']}")\n\n# Show all expenses sorted by cost\nprint("\\n=== All Expenses Sorted by Cost (Ascending) ===")\nsorted_expenses = final_df.sort_values(\'cost\')[[\'expense_description\', \'cost\', \'category\', \'event_name\', \'event_date\']]\nprint(sorted_expenses.to_string(index=False))'} 
