 action_input: {'code': 'import json\nimport pandas as pd\n\n# Load the JSON files\nwith open(\'json/member.json\', \'r\') as f:\n    member_data = json.load(f)\n\nwith open(\'json/expense.json\', \'r\') as f:\n    expense_data = json.load(f)\n\n# Create DataFrames\nmembers_df = pd.DataFrame(member_data[\'records\'])\nexpenses_df = pd.DataFrame(expense_data[\'records\'])\n\n# Target member ID\ntarget_member_id = \'rec4BLdZHS2Blfp4v\'\n\n# Get member info\nmember_info = members_df[members_df[\'member_id\'] == target_member_id]\nfull_name = f"{member_info[\'first_name\'].values[0]} {member_info[\'last_name\'].values[0]}"\nposition = member_info[\'position\'].values[0]\nemail = member_info[\'email\'].values[0]\n\n# Filter expenses for this member\nmember_expenses = expenses_df[expenses_df[\'link_to_member\'] == target_member_id]\ntotal_cost = member_expenses[\'cost\'].sum()\nnum_expenses = len(member_expenses)\n\nprint(f"Member ID: {target_member_id}")\nprint(f"Full Name: {full_name}")\nprint(f"Position: {position}")\nprint(f"Email: {email}")\nprint(f"\\nTotal Expenses: {num_expenses}")\nprint(f"Total Cost: ${total_cost:.2f}")\nprint(f"\\nExpense Details:")\nfor idx, row in member_expenses.iterrows():\n    print(f"  - {row[\'expense_description\']}: ${row[\'cost\']:.2f} ({row[\'expense_date\']})")'} 
