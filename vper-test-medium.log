 action_input: {'code': 'import pandas as pd\nimport sqlite3\n\n# Read the FRPM CSV file\ndf_frpm = pd.read_csv(\'csv/frpm.csv\')\n\n# Connect to the SQLite database and read SAT scores\nconn = sqlite3.connect(\'db/satscores.db\')\ndf_sats = pd.read_sql_query(\'SELECT * FROM satscores\', conn)\nconn.close()\n\n# Convert CDSCode/cds to string for consistent merging\ndf_frpm[\'CDSCode\'] = df_frpm[\'CDSCode\'].astype(str)\ndf_sats[\'cds\'] = df_sats[\'cds\'].astype(str)\n\n# Rename columns for consistency\ndf_sats = df_sats.rename(columns={\'cds\': \'CDSCode\', \'cname\': \'County Name\'})\n\n# Merge the two datasets on CDSCode\ndf_merged = pd.merge(df_frpm, df_sats[[\'CDSCode\', \'AvgScrMath\', \'NumTstTakr\', \'sname\']], \n                     on=\'CDSCode\', how=\'inner\')\n\n# Filter for schools with average SAT Math score > 400\ndf_filtered = df_merged[df_merged[\'AvgScrMath\'] > 400].copy()\n\nprint("Total schools with AvgScrMath > 400:", len(df_filtered))\n\n# Select relevant columns: School Name, County Name, Charter Funding Type\ndf_result = df_filtered[[\'School Name\', \'County Name\', \'Charter Funding Type\']].copy()\n\n# Sort by School Name for better readability\ndf_result = df_result.sort_values([\'County Name\', \'School Name\']).reset_index(drop=True)\n\nprint("\\nSample of filtered results (first 20 rows):")\nprint(df_result.head(20).to_string())\n\nprint("\\n\\nUnique Charter Funding Types found:")\nprint(df_result[\'Charter Funding Type\'].value_counts())'} 
