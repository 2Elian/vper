 action_input: {'code': 'import pandas as pd\nimport sqlite3\n\n# Read the FRPM CSV file\ndf_frpm = pd.read_csv(\'csv/frpm.csv\')\n\n# Connect to the SQLite database and read SAT scores\nconn = sqlite3.connect(\'db/satscores.db\')\ndf_sats = pd.read_sql_query(\'SELECT * FROM satscores\', conn)\nconn.close()\n\n# Rename columns for consistency\ndf_sats = df_sats.rename(columns={\'cds\': \'CDSCode\', \'cname\': \'County Name\'})\n\n# Merge the two datasets on CDSCode\ndf_merged = pd.merge(df_frpm, df_sats[[\'CDSCode\', \'AvgScrMath\', \'NumTstTakr\', \'sname\']], \n                     on=\'CDSCode\', how=\'inner\')\n\nprint("Merged DataFrame shape:", df_merged.shape)\nprint("\\nColumns in merged data:", list(df_merged.columns))\n\n# Filter for Riverside county\ndf_riverside = df_merged[df_merged[\'County Name\'] == \'Riverside\'].copy()\nprint("\\nRiverside County schools after merge:", len(df_riverside))\n\n# Group by school and calculate average SAT Math scores\ndf_school_avg = df_riverside.groupby([\'CDSCode\', \'School Name\', \'District Name\']).agg({\n    \'AvgScrMath\': \'mean\',\n    \'NumTstTakr\': \'sum\'\n}).reset_index()\n\ndf_school_avg = df_school_avg.sort_values(\'AvgScrMath\', ascending=False)\n\nprint("\\nTop 20 Riverside Schools by Average SAT Math Score:")\nprint(df_school_avg.head(20).to_string())'} 
